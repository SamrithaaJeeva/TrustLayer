{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyOe3eY/8ZJCP9/1vTOnqFgX"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":2,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"IUBBapUsE8n5","executionInfo":{"status":"ok","timestamp":1775067094645,"user_tz":-330,"elapsed":14938,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}},"outputId":"b8005584-968d-4bb5-e4d0-c8d0f7d4ea4a"},"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}],"source":["from google.colab import drive\n","drive.mount('/content/drive')\n"]},{"cell_type":"markdown","source":["Bimodal Fusion – Liveness Detection\n","=====================================\n","Combines any two of the three unimodal models:\n","  - Face  (face_val_predictions_final.csv)\n","  - Voice (voice_val_predictions_final.csv)\n","  - Keystroke (keystroke_val_predictions_final.csv)\n","\n","Fusion strategy: Score-level fusion using weighted average of spoof probabilities.\n","\n","Input  : fusion_val_predictions.csv   (joint validation set, 95 samples)\n","\n","Outputs: bimodal_results.csv          (per-sample predictions for all 3 pairs)\n","         bimodal_summary.csv          (accuracy / precision / recall / F1 per pair)\n"],"metadata":{"id":"YIvNI4a6Pqua"}},{"cell_type":"code","source":["import pandas as pd\n","import numpy as np\n","from sklearn.metrics import (\n","    accuracy_score, precision_score, recall_score,\n","    f1_score, confusion_matrix, classification_report, roc_auc_score\n",")\n","import warnings\n","warnings.filterwarnings(\"ignore\")"],"metadata":{"id":"U0FlSRmcPvz5","executionInfo":{"status":"ok","timestamp":1775067175046,"user_tz":-330,"elapsed":3007,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["# ──────────────────────────────────────────────────────────────\n","# 1.  LOAD DATA\n","# ──────────────────────────────────────────────────────────────\n","df = pd.read_csv(\"/content/drive/MyDrive/Final_Dataset/Sam_final_dataset/Predictions/fusion_val_predictions.csv\")\n","\n","print(\"=\" * 60)\n","print(\"BIMODAL FUSION – LIVENESS DETECTION\")\n","print(\"=\" * 60)\n","print(f\"Total samples  : {len(df)}\")\n","print(f\"Genuine (0)    : {(df['true_label'] == 0).sum()}\")\n","print(f\"Spoof   (1)    : {(df['true_label'] == 1).sum()}\")\n","print(f\"Attack types   : {df['attack_type'].value_counts().to_dict()}\\n\")\n","\n","y_true = df[\"true_label\"]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"vvh3Dt2DP8fn","executionInfo":{"status":"ok","timestamp":1775067216288,"user_tz":-330,"elapsed":1611,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}},"outputId":"ee80e08e-dc79-428c-ac19-1bc19d2ce200"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","BIMODAL FUSION – LIVENESS DETECTION\n","============================================================\n","Total samples  : 95\n","Genuine (0)    : 24\n","Spoof   (1)    : 71\n","Attack types   : {'tts': 25, 'genuine': 24, 'logical': 17, 'replay': 15, 'synthetic': 14}\n","\n"]}]},{"cell_type":"code","source":["# ──────────────────────────────────────────────────────────────\n","# 2.  DEFINE THE THREE BIMODAL PAIRS\n","# ──────────────────────────────────────────────────────────────\n","# Each pair uses a weighted average of the two spoof probabilities.\n","# Weights are equal (0.5 / 0.5) — standard score-level fusion.\n","# Threshold = 0.5  →  prob >= 0.5 → spoof (1), else genuine (0)\n","\n","PAIRS = {\n","    \"Face + Voice\": {\n","        \"prob_col\": \"fv_prob_spoof\",\n","        \"pred_col\": \"fv_pred\",\n","        \"weights\":  (0.5, 0.5),\n","        \"modalities\": (\"face\", \"voice\"),\n","    },\n","    \"Face + Keystroke\": {\n","        \"prob_col\": \"fk_prob_spoof\",\n","        \"pred_col\": \"fk_pred\",\n","        \"weights\":  (0.5, 0.5),\n","        \"modalities\": (\"face\", \"keystroke\"),\n","    },\n","    \"Voice + Keystroke\": {\n","        \"prob_col\": \"vk_prob_spoof\",\n","        \"pred_col\": \"vk_pred\",\n","        \"weights\":  (0.5, 0.5),\n","        \"modalities\": (\"voice\", \"keystroke\"),\n","    },\n","}"],"metadata":{"id":"bJFFh6o6QHrB","executionInfo":{"status":"ok","timestamp":1775067236024,"user_tz":-330,"elapsed":10,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}}},"execution_count":6,"outputs":[]},{"cell_type":"code","source":["# ──────────────────────────────────────────────────────────────\n","# 3.  EVALUATE EACH PAIR\n","# ──────────────────────────────────────────────────────────────\n","summary_rows = []\n","\n","for pair_name, cfg in PAIRS.items():\n","\n","    prob_col = cfg[\"prob_col\"]\n","    pred_col = cfg[\"pred_col\"]\n","\n","    # Re-compute fusion prob from raw modality probs (verify / override pre-computed col)\n","    m1, m2 = cfg[\"modalities\"]\n","    w1, w2 = cfg[\"weights\"]\n","    recomputed_prob = (\n","        w1 * df[f\"{m1}_prob_spoof\"] +\n","        w2 * df[f\"{m2}_prob_spoof\"]\n","    )\n","    df[f\"{pair_name}_prob\"]  = recomputed_prob.round(6)\n","    df[f\"{pair_name}_pred\"]  = (recomputed_prob >= 0.5).astype(int)\n","\n","    y_pred = df[f\"{pair_name}_pred\"]\n","    y_prob = df[f\"{pair_name}_prob\"]\n","\n","    acc   = accuracy_score(y_true, y_pred)\n","    prec  = precision_score(y_true, y_pred, zero_division=0)\n","    rec   = recall_score(y_true, y_pred, zero_division=0)\n","    f1    = f1_score(y_true, y_pred, zero_division=0)\n","    auc   = roc_auc_score(y_true, y_prob)\n","    cm    = confusion_matrix(y_true, y_pred)\n","    tn, fp, fn, tp = cm.ravel()\n","    far   = fp / (fp + tn) if (fp + tn) > 0 else 0   # False Accept Rate\n","    frr   = fn / (fn + tp) if (fn + tp) > 0 else 0   # False Reject Rate\n","\n","    print(f\"\\n{'─' * 60}\")\n","    print(f\"  {pair_name}  (weights: {w1:.1f} / {w2:.1f})\")\n","    print(f\"{'─' * 60}\")\n","    print(f\"  Accuracy  : {acc*100:.2f}%\")\n","    print(f\"  Precision : {prec*100:.2f}%  (spoof class)\")\n","    print(f\"  Recall    : {rec*100:.2f}%  (spoof class)\")\n","    print(f\"  F1-Score  : {f1*100:.2f}%\")\n","    print(f\"  AUC-ROC   : {auc:.4f}\")\n","    print(f\"  FAR       : {far*100:.2f}%\")\n","    print(f\"  FRR       : {frr*100:.2f}%\")\n","    print(f\"\\n  Confusion Matrix (rows=Actual, cols=Predicted):\")\n","    print(f\"               Genuine  Spoof\")\n","    print(f\"  Genuine  :   {tn:>5}    {fp:>5}\")\n","    print(f\"  Spoof    :   {fn:>5}    {tp:>5}\")\n","    print(f\"\\n  Classification Report:\")\n","    print(classification_report(y_true, y_pred,\n","                                target_names=[\"Genuine\", \"Spoof\"], digits=4))\n","\n","    summary_rows.append({\n","        \"Fusion Pair\":  pair_name,\n","        \"Weights\":      f\"{w1}/{w2}\",\n","        \"Samples\":      len(df),\n","        \"Accuracy (%)\": round(acc * 100, 2),\n","        \"Precision (%)\":round(prec * 100, 2),\n","        \"Recall (%)\":   round(rec * 100, 2),\n","        \"F1-Score (%)\": round(f1 * 100, 2),\n","        \"AUC-ROC\":      round(auc, 4),\n","        \"FAR (%)\":      round(far * 100, 2),\n","        \"FRR (%)\":      round(frr * 100, 2),\n","        \"TP\": int(tp), \"TN\": int(tn), \"FP\": int(fp), \"FN\": int(fn),\n","    })\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"4S2RX8kVQJBM","executionInfo":{"status":"ok","timestamp":1775067269070,"user_tz":-330,"elapsed":129,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}},"outputId":"cfae2e66-d8ed-429b-ac9d-1fe379430df1"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":[