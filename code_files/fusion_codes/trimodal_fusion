e":"Samritha Jeevaratnam","userId":"15890055633810522064"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["# ──────────────────────────────────────────────────────────────\n","# 1.  LOAD DATA\n","# ──────────────────────────────────────────────────────────────\n","df = pd.read_csv(\"/content/drive/MyDrive/Final_Dataset/Sam_final_dataset/Predictions/fusion_val_predictions.csv\")\n","\n","print(\"=\" * 60)\n","print(\"TRIMODAL FUSION – LIVENESS DETECTION\")\n","print(\"=\" * 60)\n","print(f\"Total samples  : {len(df)}\")\n","print(f\"Genuine (0)    : {(df['true_label'] == 0).sum()}\")\n","print(f\"Spoof   (1)    : {(df['true_label'] == 1).sum()}\")\n","print(f\"Attack types   : {df['attack_type'].value_counts().to_dict()}\\n\")\n","\n","y_true = df[\"true_label\"]"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"kRTfoxVxXhDx","executionInfo":{"status":"ok","timestamp":1775069208924,"user_tz":-330,"elapsed":2049,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}},"outputId":"5cca6af9-233e-4aa4-e9b2-788b7e6e9a5e"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["============================================================\n","TRIMODAL FUSION – LIVENESS DETECTION\n","============================================================\n","Total samples  : 95\n","Genuine (0)    : 24\n","Spoof   (1)    : 71\n","Attack types   : {'tts': 25, 'genuine': 24, 'logical': 17, 'replay': 15, 'synthetic': 14}\n","\n"]}]},{"cell_type":"code","source":["# ──────────────────────────────────────────────────────────────\n","# 2.  INDIVIDUAL MODEL ACCURACIES (on this joint set)\n","#     Used to compute performance-weighted fusion weights\n","# ──────────────────────────────────────────────────────────────\n","face_acc  = accuracy_score(y_true, df[\"face_pred\"])\n","voice_acc = accuracy_score(y_true, df[\"voice_pred\"])\n","ks_acc    = accuracy_score(y_true, df[\"keystroke_pred\"])\n","total_acc = face_acc + voice_acc + ks_acc\n","\n","# Normalize to sum to 1\n","w_face  = round(face_acc  / total_acc, 4)\n","w_voice = round(voice_acc / total_acc, 4)\n","w_ks    = round(ks_acc    / total_acc, 4)\n","\n","print(\"Individual model accuracy on joint set:\")\n","print(f\"  Face       : {face_acc*100:.2f}%  → weight {w_face:.4f}\")\n","print(f\"  Voice      : {voice_acc*100:.2f}%  → weight {w_voice:.4f}\")\n","print(f\"  Keystroke  : {ks_acc*100:.2f}%  → weight {w_ks:.4f}\\n\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"1xaWJGO_YE6A","executionInfo":{"status":"ok","timestamp":1775069321846,"user_tz":-330,"elapsed":23,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}},"outputId":"87a81f0c-829b-43de-8d5e-057455ddd7fb"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["Individual model accuracy on joint set:\n","  Face       : 89.47%  → weight 0.3469\n","  Voice      : 83.16%  → weight 0.3224\n","  Keystroke  : 85.26%  → weight 0.3306\n","\n"]}]},{"cell_type":"code","source":["# ──────────────────────────────────────────────────────────────\n","# 3.  DEFINE FUSION STRATEGIES\n","# ──────────────────────────────────────────────────────────────\n","STRATEGIES = {\n","    \"Equal Weight (1/3 each)\": {\n","        \"type\":    \"score\",\n","        \"weights\": (1/3, 1/3, 1/3),\n","    },\n","    \"Performance Weighted\": {\n","        \"type\":    \"score\",\n","        \"weights\": (w_face, w_voice, w_ks),\n","    },\n","    \"Majority Vote\": {\n","        \"type\": \"vote\",\n","    },\n","}"],"metadata":{"id":"Zjk_1s46Yf90","executionInfo":{"status":"ok","timestamp":1775069431981,"user_tz":-330,"elapsed":5,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}}},"execution_count":7,"outputs":[]},{"cell_type":"code","source":["# ──────────────────────────────────────────────────────────────\n","# 4.  EVALUATE EACH STRATEGY\n","# ──────────────────────────────────────────────────────────────\n","summary_rows = []\n","\n","for strategy_name, cfg in STRATEGIES.items():\n","\n","    if cfg[\"type\"] == \"score\":\n","        wf, wv, wk = cfg[\"weights\"]\n","        fused_prob = (\n","            wf * df[\"face_prob_spoof\"] +\n","            wv * df[\"voice_prob_spoof\"] +\n","            wk * df[\"keystroke_prob_spoof\"]\n","        )\n","        fused_pred = (fused_prob >= 0.5).astype(int)\n","        df[f\"{strategy_name}_prob\"] = fused_prob.round(6)\n","        df[f\"{strategy_name}_pred\"] = fused_pred\n","\n","    elif cfg[\"type\"] == \"vote\":\n","        # Hard majority vote: 2 out of 3 votes → spoof\n","        votes = (\n","            df[\"face_pred\"] +\n","            df[\"voice_pred\"] +\n","            df[\"keystroke_pred\"]\n","        )\n","        fused_pred = (votes >= 2).astype(int)\n","        fused_prob = votes / 3.0          # proportion as soft score\n","        df[f\"{strategy_name}_prob\"] = fused_prob.round(6)\n","        df[f\"{strategy_name}_pred\"] = fused_pred\n","\n","    y_pred = df[f\"{strategy_name}_pred\"]\n","    y_prob = df[f\"{strategy_name}_prob\"]\n","\n","    acc   = accuracy_score(y_true, y_pred)\n","    prec  = precision_score(y_true, y_pred, zero_division=0)\n","    rec   = recall_score(y_true, y_pred, zero_division=0)\n","    f1    = f1_score(y_true, y_pred, zero_division=0)\n","    auc   = roc_auc_score(y_true, y_prob)\n","    cm    = confusion_matrix(y_true, y_pred)\n","    tn, fp, fn, tp = cm.ravel()\n","    far   = fp / (fp + tn) if (fp + tn) > 0 else 0\n","    frr   = fn / (fn + tp) if (fn + tp) > 0 else 0\n","\n","    print(f\"\\n{'─' * 60}\")\n","    print(f\"  {strategy_name}\")\n","    if cfg[\"type\"] == \"score\":\n","        wf, wv, wk = cfg[\"weights\"]\n","        print(f\"  Weights  →  Face:{wf:.4f}  Voice:{wv:.4f}  Keystroke:{wk:.4f}\")\n","    print(f\"{'─' * 60}\")\n","    print(f\"  Accuracy  : {acc*100:.2f}%\")\n","    print(f\"  Precision : {prec*100:.2f}%  (spoof class)\")\n","    print(f\"  Recall    : {rec*100:.2f}%  (spoof class)\")\n","    print(f\"  F1-Score  : {f1*100:.2f}%\")\n","    print(f\"  AUC-ROC   : {auc:.4f}\")\n","    print(f\"  FAR       : {far*100:.2f}%\")\n","    print(f\"  FRR       : {frr*100:.2f}%\")\n","    print(f\"\\n  Confusion Matrix (rows=Actual, cols=Predicted):\")\n","    print(f\"               Genuine  Spoof\")\n","    print(f\"  Genuine  :   {tn:>5}    {fp:>5}\")\n","    print(f\"  Spoof    :   {fn:>5}    {tp:>5}\")\n","    print(f\"\\n  Classification Report:\")\n","    print(classification_report(y_true, y_pred,\n","                                target_names=[\"Genuine\", \"Spoof\"], digits=4))\n","\n","    summary_rows.append({\n","        \"Strategy\":     strategy_name,\n","        \"Samples\":      len(df),\n","        \"Accuracy (%)\": round(acc * 100, 2),\n","        \"Precision (%)\":round(prec * 100, 2),\n","        \"Recall (%)\":   round(rec * 100, 2),\n","        \"F1-Score (%)\": round(f1 * 100, 2),\n","        \"AUC-ROC\":      round(auc, 4),\n","        \"FAR (%)\":      round(far * 100, 2),\n","        \"FRR (%)\":      round(frr * 100, 2),\n","        \"TP\": int(tp), \"TN\": int(tn), \"FP\": int(fp), \"FN\": int(fn),\n","    })"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"oWuvpVPXYkJA","executionInfo":{"status":"ok","timestamp":1775069449930,"user_tz":-330,"elapsed":157,"user":{"displayName":"Samritha Jeevaratnam","userId":"15890055633810522064"}},"outputId":"9cb0419d-bca5-4948-d947-cfe77aeca086"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","────────────────────────────────────────────────────────────\n","  Equal Weight (1/3 each)\n","  Weights  →  Face:0.3333  Voice:0.3333  Keystroke:0.3333\n","────────────────────────────────────────────────────────────\n","  Accuracy  : 96.84%\n","  Precision : 98.57%  (spoof class)\n","  Recall    : 97.18%  (spoof class)\n","  F1-Score  : 97.87%\n","  AUC-ROC   : 0.9959\n